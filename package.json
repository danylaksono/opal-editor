{
  "name": "@opal/root",
  "description": "Offline-first LaTeX editor with pluggable AI",
  "version": "1.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/danylaksono/tectonic-editor"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "pnpm --filter=@opal/desktop tauri dev",
    "build:desktop": "pnpm --filter=@opal/desktop tauri build",
    "lint": "pnpm exec biome check",
    "lint:fix": "pnpm exec biome check --fix",
    "test:release-notes": "node --test scripts/release-notes.test.mjs",
    "release": "echo 'To release: git tag v<version> && git push origin v<version>'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "husky": "^9.1.7",
    "turbo": "^2.9.14"
  },
  "packageManager": "pnpm@10.28.2"
}
